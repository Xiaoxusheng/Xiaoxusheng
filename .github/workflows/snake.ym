name: Generate Snake

on:
  schedule: [{ cron: "0 0 * * *" }]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: Platane/snk@v3
        id: snake
        with:
          github_user_name: Xiaoxusheng
          svg_out_path: github-contribution-grid-snake.svg
      - uses: EndBug/add-and-commit@v9
        with:
          message: "Update snake animation"
